SUB GTO
A = INSTR(A$, " ")
B = VAL(MID$(A$, A, LEN(A$)))
J = B / 10
FOR K = J TO LN
A$ = A$(K)
IF LN = 0 THEN
PRINT "Missing Operand Error"
END IF
COMMANDS
NEXT K
END SUB

SUB INPT
